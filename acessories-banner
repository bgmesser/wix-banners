const t=document.getElementById('track');
[...logos,...logos].forEach(({src,href})=>{
  const d=document.createElement(href?'a':'div');
  d.className='logo';
  if(href){d.href=href;d.target='_blank';d.rel='noopener noreferrer';}
  const i=new Image();
  i.src=src;
  i.onload=()=>{const r=i.naturalWidth/i.naturalHeight;let s=1.55;if(r>3)s=1.8;else if(r>2)s=1.68;else if(r>1.5)s=1.55;else if(r<0.8)s=1.4;i.style.transform=`scale(${s})`;};
  d.appendChild(i);
  t.appendChild(d);
});
