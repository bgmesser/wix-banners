<!DOCTYPE html><html><head><meta charset="UTF-8"><meta name="viewport" content="width=device-width,initial-scale=1"><style>
html,body{margin:0;overflow:hidden}
.banner{position:relative;height:140px;display:flex;align-items:center;overflow:hidden}
.banner:before,.banner:after{content:'';position:absolute;top:0;width:80px;height:100%;pointer-events:none;z-index:2}
.banner:before{left:0;background:linear-gradient(to right,#bfbfbf,transparent)}
.banner:after{right:0;background:linear-gradient(to left,#bfbfbf,transparent)}
.track{display:flex;align-items:center;gap:38px;animation:scroll 40s linear infinite}
.track:hover{animation-play-state:paused}
.logo{width:198px;height:115px;display:flex;justify-content:center;align-items:center;flex-shrink:0;transition:transform .25s ease,filter .25s ease;cursor:default}
.logo:hover{transform:scale(1.08);filter:drop-shadow(0 6px 14px rgba(0,0,0,.25))}
a.logo{cursor:pointer;text-decoration:none}
.logo img{max-width:205%;max-height:205%;object-fit:contain}
@keyframes scroll{from{transform:translateX(0)}to{transform:translateX(-50%)}}
</style></head><body><div class="banner"><div id="track" class="track"></div></div><script>
